# Nomor WhatsApp tujuan lead (format 62xxxx, tanpa +). Default: 62811944288
NEXT_PUBLIC_WA_NUMBER=62811944288

# URL produksi (untuk metadata OG / canonical)
NEXT_PUBLIC_SITE_URL=https://drwversity.com

# Meta Pixel ID (angka). Kosongkan untuk nonaktif. Default fallback di kode.
NEXT_PUBLIC_META_PIXEL_ID=

# TikTok Pixel ID (angka). Kosongkan untuk nonaktif.
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Google Tag Manager ID (format GTM-XXXXXX). Kosongkan untuk nonaktif.
NEXT_PUBLIC_GTM_ID=

# (Opsional) Meta Conversion API — untuk /api/meta-pixel server-side tracking
META_PIXEL_ID=
META_ACCESS_TOKEN=
